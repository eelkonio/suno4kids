# =============================================================
# AI Song Workshop - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#   nano .env
# =============================================================

# --- API Keys (required) ---
# Get your Anthropic API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your Suno API key at: https://suno.com/ (via API provider)
SUNO_API_KEY=your_suno_api_key_here

# Get your Google API key at: https://aistudio.google.com/apikey
# Used for image generation (Gemini) and photo transformations
GOOGLE_API_KEY=your_google_api_key_here

# --- Authentication ---
# Format: "username1:password1,username2:password2"
# The first user is the regular user, add an admin user for admin features
AUTH_USERS=student:schoolpassword,admin:adminpassword

# Which username gets admin access (sees "Alle Liedjes" and "Alle Foto's")
ADMIN_USERNAME=admin

# --- Callback URL for Suno API ---
# Replace YOUR_DOMAIN with your actual domain or EC2 public DNS
CALLBACK_URL=https://YOUR_DOMAIN/api/suno/callback

# --- Header Configuration ---
LOGO_PATH=static/logo.png
CLASS_NAME=Your Class Name

# --- Session Configuration ---
SESSION_TIMEOUT_HOURS=8
SESSION_STORAGE_PATH=/tmp/workshop_sessions

# --- Server Configuration ---
# For production behind nginx, use localhost:5000
# For local development without nginx, use 0.0.0.0:5000
FLASK_ENV=production
FLASK_DEBUG=False
HOST=localhost
PORT=5000
