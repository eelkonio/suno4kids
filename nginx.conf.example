# =============================================================
# AI Song Workshop - Nginx Configuration Template
# =============================================================
# Replace YOUR_DOMAIN with your actual domain name, then:
#   sudo cp nginx.conf.example /etc/nginx/conf.d/workshop.conf
#   sudo nginx -t
#   sudo systemctl reload nginx
#
# SSL certificates will be added by Certbot (see SETUP_GUIDE.md)
# =============================================================

# HTTP to HTTPS redirect
server {
    listen 80;
    server_name YOUR_DOMAIN;
    return 301 https://$server_name$request_uri;
}

# HTTPS server
server {
    listen 443 ssl;
    server_name YOUR_DOMAIN;

    # SSL certificate paths (configured by Certbot)
    ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    # SSL settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Proxy to Flask
    location / {
        proxy_pass http://localhost:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Long timeouts for AI image generation (can take 30-60s)
        proxy_connect_timeout 300;
        proxy_send_timeout 300;
        proxy_read_timeout 300;
    }

    # Max upload size for webcam photos
    client_max_body_size 10M;
}
